{{ 'section-contact-info-cards.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="contact-info-cards color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    {%- unless section.settings.heading == blank -%}
      <h2 class="contact-info-cards__heading inline-richtext {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endunless -%}

    <ul
      class="contact-info-cards__list grid grid--1-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
      role="list"
    >
      {%- for block in section.blocks -%}
        <li
          class="contact-info-cards__item grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="contact-info-cards__card content-container">
            {%- if block.settings.icon_name != blank -%}
              <div class="contact-info-cards__icon" aria-hidden="true">
                <span class="material-symbols-outlined">{{- block.settings.icon_name | escape -}}</span>
              </div>
            {%- endif -%}
            <div class="contact-info-cards__body">
              {%- unless block.settings.title == blank -%}
                <h3 class="contact-info-cards__card-heading">{{ block.settings.title }}</h3>
              {%- endunless -%}
              {%- if block.settings.content != blank -%}
                <div class="contact-info-cards__content rte">{{ block.settings.content }}</div>
              {%- endif -%}
              {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="contact-info-cards__link">
                  {{ block.settings.link_label }}
                  <span class="material-symbols-outlined contact-info-cards__link-arrow" aria-hidden="true">arrow_forward</span>
                </a>
              {%- endif -%}
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Contact Info Cards",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info card",
      "settings": [
        {
          "type": "text",
          "id": "icon_name",
          "label": "Icon name (Material Symbols)",
          "default": "support_agent",
          "info": "예: support_agent, schedule, help, location_on"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card title",
          "default": "Direct Support"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>hello@neatandco.com<br>Response within 24 hours.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Info Cards",
      "blocks": [
        {
          "type": "info_card",
          "settings": {
            "icon_name": "support_agent",
            "title": "Direct Support",
            "content": "<p>hello@neatandco.com<br>Response within 24 hours.</p>"
          }
        },
        {
          "type": "info_card",
          "settings": {
            "icon_name": "schedule",
            "title": "Office Hours",
            "content": "<p>Monday – Friday<br>9:00 AM – 6:00 PM PST</p>"
          }
        },
        {
          "type": "info_card",
          "settings": {
            "icon_name": "help",
            "title": "FAQ",
            "content": "<p>Find answers to the most common questions about shipping, returns, and our products.</p>",
            "link_label": "Visit FAQ",
            "link_url": "shopify://pages/faq"
          }
        },
        {
          "type": "info_card",
          "settings": {
            "icon_name": "location_on",
            "title": "Mailing Address",
            "content": "<p>NEAT & CO Inc.<br>300 Park Avenue, Suite 1800<br>New York, NY 10022</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
