{{ 'section-about-team.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="about-team color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    <div class="about-team__header">
      {%- unless section.settings.heading == blank -%}
        <h2 class="about-team__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endunless -%}
      {%- if section.settings.description != blank -%}
        <p class="about-team__description rte">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <ul
      class="about-team__list grid grid--1-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
      role="list"
    >
      {%- for block in section.blocks -%}
        <li
          class="about-team__item grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="about-team__card">

            <div class="about-team__avatar">
              {%- if block.settings.photo != blank -%}
                {{
                  block.settings.photo
                  | image_url: width: 400
                  | image_tag:
                    loading: 'lazy',
                    class: 'about-team__photo',
                    alt: block.settings.name | escape
                }}
              {%- else -%}
                <div class="about-team__avatar-placeholder" aria-hidden="true">
                  {{ block.settings.name | slice: 0 | upcase }}
                </div>
              {%- endif -%}
            </div>

            <div class="about-team__info">
              {%- if block.settings.name != blank -%}
                <h3 class="about-team__name">{{ block.settings.name }}</h3>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <p class="about-team__role">{{ block.settings.role }}</p>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="about-team__bio rte">{{ block.settings.bio }}</p>
              {%- endif -%}
            </div>

          </div>
        </li>
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "About Team",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the Visionaries"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team member",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Elena Vance"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / Title",
          "default": "Co-Founder & Head of Design"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Bio",
          "default": "A former interior architect with 12 years of studio experience, Elena built NEAT & CO to bring the discipline of professional space-planning into everyday homes."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Team",
      "blocks": [
        {
          "type": "team_member",
          "settings": {
            "name": "Elena Vance",
            "role": "Co-Founder & Head of Design",
            "bio": "A former interior architect with 12 years of studio experience, Elena built NEAT & CO to bring the discipline of professional space-planning into everyday homes."
          }
        },
        {
          "type": "team_member",
          "settings": {
            "name": "Marcus Reid",
            "role": "Co-Founder & Head of Product",
            "bio": "Marcus spent a decade in consumer goods engineering before joining Elena to develop the modular systems at the core of the NEAT & CO lineup."
          }
        }
      ]
    }
  ]
}
{% endschema %}
