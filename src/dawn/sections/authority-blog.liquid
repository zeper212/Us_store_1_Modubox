{{ 'section-authority-blog.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="authority-blog color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="authority-blog__grid">

      <!-- Left: image -->
      <div class="authority-blog__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              class: 'authority-blog__image',
              alt: section.settings.heading | escape
          }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'authority-blog__image placeholder-svg' }}
        {%- endif -%}
      </div>

      <!-- Right: text + article links -->
      <div class="authority-blog__content">

        {%- if section.settings.eyebrow != blank -%}
          <span class="authority-blog__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        {%- unless section.settings.heading == blank -%}
          <h2 class="authority-blog__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endunless -%}

        {%- if section.settings.text != blank -%}
          <p class="authority-blog__text rte">{{ section.settings.text }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="authority-blog__articles">
            {%- for block in section.blocks -%}
              <a
                href="{{ block.settings.link | default: '#' }}"
                class="authority-blog__article-link"
                {{ block.shopify_attributes }}
              >
                <div class="authority-blog__article-body">
                  {%- if block.settings.title != blank -%}
                    <h4 class="authority-blog__article-title">{{ block.settings.title }}</h4>
                  {%- endif -%}
                  {%- if block.settings.subtitle != blank -%}
                    <p class="authority-blog__article-subtitle">{{ block.settings.subtitle }}</p>
                  {%- endif -%}
                </div>
                <span class="material-symbols-outlined authority-blog__article-arrow" aria-hidden="true">
                  arrow_forward
                </span>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Authority Blog",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Expert Organizing Tips"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "5 Minutes to a Better Morning: Entryway Edition"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "The entryway is the gatekeeper of your home's energy. Discover three simple habits to eliminate 'drop-zones' and start every day with clarity."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "article_link",
      "name": "Article link",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "The Hanger Rule"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Why matching hangers are your best closet investment."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Authority Blog",
      "blocks": [
        {
          "type": "article_link",
          "settings": {
            "title": "The Hanger Rule",
            "subtitle": "Why matching hangers are your best closet investment."
          }
        },
        {
          "type": "article_link",
          "settings": {
            "title": "Decanting 101",
            "subtitle": "A guide to which dry goods belong in glass containers."
          }
        }
      ]
    }
  ]
}
{% endschema %}
