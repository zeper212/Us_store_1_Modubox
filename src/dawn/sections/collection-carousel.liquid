{{ 'section-collection-carousel.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="collection-carousel color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    <!-- Header: eyebrow + heading + nav buttons -->
    <div class="collection-carousel__header">
      <div class="collection-carousel__header-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="collection-carousel__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- unless section.settings.title == blank -%}
          <h2 class="collection-carousel__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title }}
          </h2>
        {%- endunless -%}
      </div>
      <div class="collection-carousel__nav large-up-show" aria-hidden="true">
        <button
          type="button"
          class="collection-carousel__nav-btn"
          id="CarouselPrev-{{ section.id }}"
          tabindex="-1"
        >
          <span class="material-symbols-outlined">chevron_left</span>
        </button>
        <button
          type="button"
          class="collection-carousel__nav-btn"
          id="CarouselNext-{{ section.id }}"
          tabindex="-1"
        >
          <span class="material-symbols-outlined">chevron_right</span>
        </button>
      </div>
    </div>

    <slider-component class="slider-mobile-gutter">
      <ul
        class="collection-carousel__list contains-card grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--2-col-tablet-down slider slider--tablet grid--peek"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- for block in section.blocks -%}
          {%- assign col = block.settings.collection -%}
          {%- assign display_image = block.settings.custom_image | default: col.featured_image -%}
          {%- assign display_title = block.settings.custom_title -%}
          {%- if display_title == blank -%}{%- assign display_title = col.title -%}{%- endif -%}
          {%- assign col_url = col.url | default: '#' -%}
          {%- assign placeholder_index = forloop.index0 | modulo: 4 | plus: 1 -%}
          {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_index -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="collection-carousel__item grid__item slider__slide{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {%- if display_image != blank -%}
              <div class="card-wrapper animate-arrow collection-card-wrapper">
                <div class="card card--{{ settings.collection_card_style }} card--media"
                     style="--ratio-percent: 125%;">
                  <div class="card__inner ratio{% if settings.collection_card_style == 'standard' %} color-{{ settings.collection_card_color_scheme }} gradient{% endif %}"
                       style="--ratio-percent: 125%;">
                    <div class="card__media">
                      <div class="media media--transparent media--hover-effect">
                        <img
                          srcset="
                            {%- if display_image.width >= 165 -%}{{ display_image | image_url: width: 165 }} 165w,{%- endif -%}
                            {%- if display_image.width >= 330 -%}{{ display_image | image_url: width: 330 }} 330w,{%- endif -%}
                            {%- if display_image.width >= 535 -%}{{ display_image | image_url: width: 535 }} 535w,{%- endif -%}
                            {%- if display_image.width >= 750 -%}{{ display_image | image_url: width: 750 }} 750w,{%- endif -%}
                            {%- if display_image.width >= 1000 -%}{{ display_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                            {{ display_image | image_url }} {{ display_image.width }}w
                          "
                          src="{{ display_image | image_url: width: 750 }}"
                          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: section.settings.columns_desktop }}px, (min-width: 750px) calc((100vw - 10rem) / 2), calc(100vw - 3rem)"
                          alt="{{ display_image.alt | escape | default: display_title }}"
                          height="{{ display_image.height }}"
                          width="{{ display_image.width }}"
                          loading="lazy"
                          class="motion-reduce"
                        >
                      </div>
                    </div>
                  </div>
                  <div class="card__content">
                    <div class="card__information">
                      <h3 class="card__heading">
                        <a href="{{ col_url }}" class="full-unstyled-link">
                          {{ display_title }}
                          <svg aria-hidden="true" focusable="false" class="icon icon-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 10">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"/>
                          </svg>
                        </a>
                      </h3>
                    </div>
                  </div>
                </div>
              </div>
            {%- else -%}
              {% render 'card-collection',
                card_collection: col,
                media_aspect_ratio: 'portrait',
                columns: section.settings.columns_desktop,
                placeholder_image: placeholder_image
              %}
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>

      <div class="slider-buttons">
        <button
          type="button"
          class="slider-button slider-button--prev"
          name="previous"
          aria-label="{{ 'general.slider.previous_slide' | t }}"
        >
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
        <div class="slider-counter caption">
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ section.blocks.size }}</span>
        </div>
        <button
          type="button"
          class="slider-button slider-button--next"
          name="next"
          aria-label="{{ 'general.slider.next_slide' | t }}"
        >
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
      </div>
    </slider-component>

  </div>
</div>

<!-- Wire header nav buttons to Dawn's slider-component -->
<script>
  (function () {
    var sliderEl = document.getElementById('Slider-{{ section.id }}');
    if (!sliderEl) return;
    var component = sliderEl.closest('slider-component');
    var prevBtn   = document.getElementById('CarouselPrev-{{ section.id }}');
    var nextBtn   = document.getElementById('CarouselNext-{{ section.id }}');
    if (component && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', function () {
        component.querySelector('.slider-button--prev').click();
      });
      nextBtn.addEventListener('click', function () {
        component.querySelector('.slider-button--next').click();
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Collection Carousel",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Collections"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Space"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image",
          "info": "Overrides the collection's default image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "info": "Overrides the collection name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Carousel",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}
