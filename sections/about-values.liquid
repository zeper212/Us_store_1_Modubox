{{ 'section-about-values.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="about-values color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    <div class="about-values__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="about-values__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- unless section.settings.heading == blank -%}
        <h2 class="about-values__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endunless -%}
      {%- if section.settings.description != blank -%}
        <p class="about-values__description rte">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <ul
      class="about-values__list grid grid--1-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
      role="list"
    >
      {%- for block in section.blocks -%}
        <li
          class="about-values__item grid__item center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="about-values__card content-container">
            {%- if block.settings.icon_name != blank -%}
              <div class="about-values__icon" aria-hidden="true">
                <span class="material-symbols-outlined">{{- block.settings.icon_name | escape -}}</span>
              </div>
            {%- endif -%}
            <div class="about-values__card-body">
              {%- unless block.settings.title == blank -%}
                <h3 class="about-values__card-heading inline-richtext">{{ block.settings.title }}</h3>
              {%- endunless -%}
              {%- if block.settings.text != blank -%}
                <p class="about-values__card-text rte">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "About Values",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Our Philosophy"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "From Professional Hands to Your Home"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "value_item",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "icon_name",
          "label": "Icon name (Material Symbols)",
          "default": "design_services",
          "info": "예: design_services, texture, view_module"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "Intentional Design"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Every product is engineered around a specific friction point in the home, not aesthetics alone."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Values",
      "blocks": [
        {
          "type": "value_item",
          "settings": {
            "icon_name": "design_services",
            "title": "Intentional Design",
            "text": "Every product is engineered around a specific friction point in the home, not aesthetics alone."
          }
        },
        {
          "type": "value_item",
          "settings": {
            "icon_name": "texture",
            "title": "Tactile Quality",
            "text": "We source materials that feel premium in the hand. BPA-free acrylic, solid bamboo, and food-grade stainless steel."
          }
        },
        {
          "type": "value_item",
          "settings": {
            "icon_name": "view_module",
            "title": "Modular Systems",
            "text": "Our products are designed to work together. Start with one piece and scale your system as your home evolves."
          }
        }
      ]
    }
  ]
}
{% endschema %}
