{{ 'section-before-after-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="before-after-hero color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
  style="--bah-height: {{ section.settings.hero_height }}px;"
>
  <div
    class="before-after-hero__slider"
    id="bah-slider-{{ section.id }}"
    style="--reveal-percent: 50%;"
  >

    <!-- After image (background, full width) -->
    <div class="before-after-hero__layer before-after-hero__layer--after">
      {%- if section.settings.after_image != blank -%}
        {{
          section.settings.after_image
          | image_url: width: 2400
          | image_tag:
            loading: 'eager',
            class: 'before-after-hero__image',
            alt: section.settings.after_label | escape
        }}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'before-after-hero__image placeholder-svg' }}
      {%- endif -%}
      {%- if section.settings.after_label != blank -%}
        <div class="before-after-hero__label before-after-hero__label--after">
          <span>{{ section.settings.after_label }}</span>
        </div>
      {%- endif -%}
    </div>

    <!-- Before image (clipped overlay) -->
    <div class="before-after-hero__layer before-after-hero__layer--before">
      {%- if section.settings.before_image != blank -%}
        {{
          section.settings.before_image
          | image_url: width: 2400
          | image_tag:
            loading: 'eager',
            class: 'before-after-hero__image before-after-hero__image--before',
            alt: section.settings.before_label | escape
        }}
      {%- else -%}
        {{ 'hero-apparel-2' | placeholder_svg_tag: 'before-after-hero__image before-after-hero__image--before placeholder-svg' }}
      {%- endif -%}
      {%- if section.settings.before_label != blank -%}
        <div class="before-after-hero__label before-after-hero__label--before">
          <span>{{ section.settings.before_label }}</span>
        </div>
      {%- endif -%}
    </div>

    <!-- Slider handle -->
    <div class="before-after-hero__handle" aria-hidden="true">
      <div class="before-after-hero__handle-circle">
        <span class="material-symbols-outlined">unfold_more</span>
      </div>
    </div>

    <!-- Range input: functional layer (invisible) -->
    <input
      class="before-after-hero__range"
      type="range"
      min="0"
      max="100"
      value="50"
      aria-label="Drag to compare before and after"
      oninput="
        var s = document.getElementById('bah-slider-{{ section.id }}');
        s.style.setProperty('--reveal-percent', this.value + '%');
      "
    >
  </div>

  <!-- Headline overlay -->
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="before-after-hero__overlay">
      <div class="before-after-hero__content">
        {%- if section.settings.heading != blank -%}
          <h1 class="before-after-hero__heading inline-richtext">
            {{ section.settings.heading }}
          </h1>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="before-after-hero__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="before-after-hero__cta"
          >
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Before / After Hero",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Before image"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before label",
      "default": "The Chaos"
    },
    {
      "type": "header",
      "content": "After image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After label",
      "default": "The Resolve"
    },
    {
      "type": "header",
      "content": "Overlay content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "The Joy of a Home in Order"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Functional minimalism meets premium craftsmanship. Rediscover your home with NEAT & CO’s curated storage solutions."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Solution"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Section height",
      "default": 700
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Before / After Hero"
    }
  ]
}
{% endschema %}
