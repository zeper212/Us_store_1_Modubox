{{ 'section-product-reviews-grid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="reviews-grid color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    <!-- Header: heading + overall rating + filter chips -->
    <div class="reviews-grid__header">
      <div class="reviews-grid__header-left">
        {%- unless section.settings.heading == blank -%}
          <h2 class="reviews-grid__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endunless -%}
        {%- if section.settings.overall_rating != blank -%}
          <div class="reviews-grid__overall">
            <div class="reviews-grid__stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                <span class="material-symbols-outlined reviews-grid__star reviews-grid__star--filled">star</span>
              {%- endfor -%}
            </div>
            <span class="reviews-grid__score">{{ section.settings.overall_rating }}</span>
            {%- if section.settings.total_reviews != blank -%}
              <span class="reviews-grid__count">({{ section.settings.total_reviews }} reviews)</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Review cards grid -->
    {%- if section.blocks.size > 0 -%}
      <ul
        class="reviews-grid__list grid grid--1-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
        role="list"
      >
        {%- for block in section.blocks -%}
          <li
            class="reviews-grid__item grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="reviews-grid__card content-container">

              <!-- Stars -->
              <div class="reviews-grid__card-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                {%- assign rating_int = block.settings.rating | round -%}
                {%- for i in (1..5) -%}
                  {%- if i <= rating_int -%}
                    <span class="material-symbols-outlined reviews-grid__star reviews-grid__star--filled" aria-hidden="true">star</span>
                  {%- else -%}
                    <span class="material-symbols-outlined reviews-grid__star reviews-grid__star--empty" aria-hidden="true">star</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <!-- Review text -->
              {%- if block.settings.text != blank -%}
                <blockquote class="reviews-grid__card-text rte">
                  <p>{{ block.settings.text }}</p>
                </blockquote>
              {%- endif -%}

              <!-- Author -->
              <div class="reviews-grid__card-author">
                <div class="reviews-grid__card-avatar" aria-hidden="true">
                  {{ block.settings.author_name | slice: 0 | upcase }}
                </div>
                <div class="reviews-grid__card-author-info">
                  {%- if block.settings.author_name != blank -%}
                    <p class="reviews-grid__card-name">{{ block.settings.author_name }}</p>
                  {%- endif -%}
                  {%- if block.settings.author_location != blank -%}
                    <p class="reviews-grid__card-location">{{ block.settings.author_location }}</p>
                  {%- endif -%}
                </div>
              </div>

            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Product Reviews Grid",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Verified Community Reviews"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "overall_rating",
      "label": "Overall rating (e.g. 4.9)",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "total_reviews",
      "label": "Total review count",
      "default": "128"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review_item",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star rating"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "\"Finally found a bin deep enough for my builder-grade pantry. The clarity is insane, feels like glass but lightweight.\""
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Author location",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Reviews Grid",
      "blocks": [
        {
          "type": "review_item",
          "settings": {
            "rating": 5,
            "text": "\"Finally found a bin deep enough for my builder-grade pantry. The clarity is insane, feels like glass but lightweight.\"",
            "author_name": "Sarah M.",
            "author_location": "Verified Buyer · Pantry"
          }
        },
        {
          "type": "review_item",
          "settings": {
            "rating": 5,
            "text": "\"Stacks perfectly. I have six of these in my fridge now. The lid is tight enough that I've had zero spills during a move.\"",
            "author_name": "James T.",
            "author_location": "Verified Buyer · Fridge"
          }
        },
        {
          "type": "review_item",
          "settings": {
            "rating": 5,
            "text": "\"Worth every penny. My pantry went from chaos to a magazine shoot in an afternoon. The clear walls make it so easy to see what I have.\"",
            "author_name": "Olivia R.",
            "author_location": "Verified Buyer · All Spaces"
          }
        }
      ]
    }
  ]
}
{% endschema %}
