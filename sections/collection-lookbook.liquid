{{ 'section-collection-lookbook.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="collection-lookbook color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    <div class="collection-lookbook__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="collection-lookbook__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- unless section.settings.title == blank -%}
        <h2 class="collection-lookbook__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      {%- endunless -%}
      {%- if section.settings.description != blank -%}
        <p class="collection-lookbook__description rte">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <ul
      class="collection-lookbook__list grid grid--2-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
      role="list"
    >
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <li
          class="collection-lookbook__item grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="collection-lookbook__card">

            <!-- Product image -->
            <div class="collection-lookbook__media">
              {%- if product != blank and product.featured_media != blank -%}
                <a href="{{ product.url }}" class="collection-lookbook__media-link">
                  {{
                    product.featured_media
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      class: 'collection-lookbook__image',
                      alt: product.featured_media.alt | escape
                  }}
                </a>
              {%- else -%}
                <div class="collection-lookbook__media-placeholder">
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'collection-lookbook__image placeholder-svg' }}
                </div>
              {%- endif -%}

              {%- if block.settings.tag_text != blank -%}
                <div class="collection-lookbook__tag">
                  <span class="material-symbols-outlined collection-lookbook__tag-icon" aria-hidden="true">sell</span>
                  <span>{{ block.settings.tag_text }}</span>
                </div>
              {%- endif -%}
            </div>

            <!-- Product info -->
            <div class="collection-lookbook__info">
              {%- if product != blank -%}
                <h3 class="collection-lookbook__product-title">
                  <a href="{{ product.url }}" class="collection-lookbook__product-link">
                    {{ product.title }}
                  </a>
                </h3>
                <p class="collection-lookbook__price">
                  {{ product.price | money }}
                </p>
              {%- elsif block.settings.product_title != blank -%}
                <h3 class="collection-lookbook__product-title">{{ block.settings.product_title }}</h3>
                {%- if block.settings.product_price != blank -%}
                  <p class="collection-lookbook__price">{{ block.settings.product_price }}</p>
                {%- endif -%}
              {%- endif -%}
              {%- if block.settings.product_subtitle != blank -%}
                <p class="collection-lookbook__subtitle rte">{{ block.settings.product_subtitle }}</p>
              {%- endif -%}
            </div>

          </div>
        </li>
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Collection Lookbook",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Curated Sets"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Shop the Look"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "lookbook_item",
      "name": "Product item",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Title (if no product linked)",
          "default": "Total Clarity Set"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Price display (if no product linked)",
          "default": "$72.00"
        },
        {
          "type": "text",
          "id": "product_subtitle",
          "label": "Subtitle / description"
        },
        {
          "type": "text",
          "id": "tag_text",
          "label": "Tag label (e.g. Best Seller)",
          "default": "Best Seller"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Lookbook",
      "blocks": [
        {
          "type": "lookbook_item",
          "settings": {
            "product_title": "Total Clarity Set",
            "product_price": "$72.00",
            "tag_text": "Best Seller"
          }
        },
        {
          "type": "lookbook_item",
          "settings": {
            "product_title": "Pantry Starter Kit",
            "product_price": "$48.00",
            "tag_text": "New"
          }
        },
        {
          "type": "lookbook_item",
          "settings": {
            "product_title": "Fridge Edition",
            "product_price": "$56.00"
          }
        },
        {
          "type": "lookbook_item",
          "settings": {
            "product_title": "The Office Set",
            "product_price": "$64.00"
          }
        }
      ]
    }
  ]
}
{% endschema %}
